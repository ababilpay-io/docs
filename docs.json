{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "AbabilPay Docs",
  "colors": {
    "primary": "#0fa8ea",
    "light": "#34c8fa",
    "dark": "#0184db"
  },
  "favicon": "/images/ababilpay-logo.webp",
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "Product Demo",
          "icon": "book-open-cover",
          "href": "https://ababilpay-io.github.io/ababilpay-desgin/"
        },
        {
          "anchor": "GitHub",
          "icon": "github",
          "href": "https://github.com/ababilpay-io"
        }
      ]
    },
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting started",
            "pages": [
              "index",
              "quickstart",
              "development"
            ]
          },
          {
            "group": "Product",
            "pages": [
              "features",
              "commerce",
              "ai-agents",
              "data-model",
              "roadmap"
            ]
          }
        ]
      },
      {
        "tab": "API reference",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "api",
              "api-reference/authentication",
              "api-reference/networks"
            ]
          },
          {
            "group": "Integration Paths",
            "pages": [
              "api-reference/hosted-gateway",
              "api-reference/custom-integration"
            ]
          },
          {
            "group": "Endpoints",
            "pages": [
              "api-reference/endpoints"
            ]
          },
          {
            "group": "AI Agents",
            "pages": [
              "api-reference/ai-agents"
            ]
          },
          {
            "group": "Reference",
            "pages": [
              "api-reference/errors"
            ]
          }
        ]
      }
    ]
  },
  "redirects": [
    {
      "source": "/feature",
      "destination": "/features"
    },
    {
      "source": "/product/feature",
      "destination": "/features"
    },
    {
      "source": "/product/features",
      "destination": "/features"
    },
    {
      "source": "/product/commerce",
      "destination": "/commerce"
    },
    {
      "source": "/commarch",
      "destination": "/commerce"
    },
    {
      "source": "/commerch",
      "destination": "/commerce"
    }
  ],
  "logo": "/images/ababilpay-logo.webp",
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:contact@ababilpay.io"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Product Demo",
      "href": "https://ababilpay-io.github.io/ababilpay-desgin/"
    }
  },
  "contextual": {
    "options": [
     "copy",
     "view",
     "chatgpt",
     "claude",
     "perplexity",
     "mcp",
     "cursor",
     "vscode"
   ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/ababilpay-io"
    }
  },
  "appearance": {
    "default": "dark"
  }
}
