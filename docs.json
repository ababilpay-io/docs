{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Ababilpay Docs",
  "colors": {
    "primary": "#0fa8ea",
    "light": "#34c8fa",
    "dark": "#0184db"
  },
  "favicon": "/images/photo_2026-01-20_01-32-02.jpg",
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "Documentation",
          "icon": "book-open-cover",
          "href": "https://mintlify.com/docs"
        },
        {
          "anchor": "Blog",
          "icon": "newspaper",
          "href": "https://mintlify.com/blog"
        }
      ]
    },
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting started",
            "pages": [
              "index",
              "quickstart",
              "development"
            ]
          }
        ]
      },
      {
        "tab": "API reference"
      }
    ]
  },
  "logo": "/images/photo_2026-01-20_01-32-02.jpg",
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:contact@ababbilpay.io"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://dashboard.mintlify.com"
    }
  },
  "contextual": {
    "options": [
     "copy",
     "view",
     "chatgpt",
     "claude",
     "perplexity",
     "mcp",
     "cursor",
     "vscode"
   ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/mintlify",
      "github": "https://github.com/mintlify",
      "linkedin": "https://linkedin.com/company/mintlify"
    }
  },
  "appearance": {
    "default": "dark"
  }
}
