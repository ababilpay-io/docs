{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "AbabilPay Docs",
  "colors": {
    "primary": "#5ffbf1",
    "light": "#7ffcf4",
    "dark": "#00c4b8"
  },
  "favicon": "/images/favicon.png",
  "logo": {
    "dark": "/logo/dark.svg",
    "light": "/logo/light.svg"
  },
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "Dashboard",
          "icon": "layout-dashboard",
          "href": "https://testnetv1.ababilpay.xyz"
        },
        {
          "anchor": "GitHub",
          "icon": "github",
          "href": "https://github.com/ababilpay-io"
        }
      ]
    },
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting started",
            "pages": [
              "index",
              "quickstart",
              "development"
            ]
          },
          {
            "group": "Product",
            "pages": [
              "features",
              "commerce",
              "ai-agents",
              "roadmap"
            ]
          }
        ]
      },
      {
        "tab": "API reference",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "api",
              "api-reference/authentication",
              "api-reference/networks"
            ]
          },
          {
            "group": "Integration paths",
            "pages": [
              "api-reference/hosted-gateway",
              "api-reference/custom-integration"
            ]
          },
          {
            "group": "Endpoints",
            "pages": [
              "api-reference/endpoints"
            ]
          },
          {
            "group": "AI agents",
            "pages": [
              "api-reference/ai-agents"
            ]
          },
          {
            "group": "Reference",
            "pages": [
              "api-reference/errors"
            ]
          }
        ]
      }
    ]
  },
  "redirects": [
    { "source": "/feature",          "destination": "/features" },
    { "source": "/product/feature",  "destination": "/features" },
    { "source": "/product/features", "destination": "/features" },
    { "source": "/product/commerce", "destination": "/commerce" },
    { "source": "/commarch",         "destination": "/commerce" },
    { "source": "/commerch",         "destination": "/commerce" },
    { "source": "/data-model",       "destination": "/features" }
  ],
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:contact@ababilpay.io"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://testnetv1.ababilpay.xyz"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/ababilpay-io"
    }
  },
  "appearance": {
    "default": "dark"
  }
}
